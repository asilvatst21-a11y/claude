# Supabase — crie um novo projeto em https://supabase.com
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Z-API — crie uma instância em https://z-api.io
VITE_ZAPI_INSTANCE=sua_instancia_aqui
VITE_ZAPI_TOKEN=seu_token_aqui
VITE_ZAPI_CLIENT_TOKEN=seu_client_token_aqui

# Service role do Supabase (usado pelo módulo de Vales/Reposições no front)
VITE_SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# ───────────────────────────────────────────────────────────────────────────
# Variáveis do servidor (Vercel) — usadas só pela função api/zapi-webhook.ts.
# NÃO precisam do prefixo VITE_ e não são expostas ao front.
# ───────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE=sua_service_role_key_aqui
ZAPI_INSTANCE=sua_instancia_aqui
ZAPI_TOKEN=seu_token_aqui
ZAPI_CLIENT_TOKEN=seu_client_token_aqui
# Segredo opcional para validar o webhook (?token=...)
ZAPI_WEBHOOK_SECRET=
# IA que interpreta a mensagem de reposição (Claude Haiku)
ANTHROPIC_API_KEY=sua_anthropic_key_aqui
# Transcrição de áudio via Whisper da Groq (tier gratuito): https://console.groq.com
GROQ_API_KEY=sua_groq_key_aqui
# Opcional — modelo de transcrição (padrão: whisper-large-v3-turbo)
GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo
